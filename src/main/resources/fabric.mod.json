{
  "schemaVersion": 1,
  "id": "redscope",
  "version": "${version}",
  "name": "RedScope",
  "description": "A small redstone debugger and visualizer for Minecraft.",
  "authors": [
    "RedScope Team"
  ],
  "contact": {
    "homepage": "https://github.com/yourusername/redscope",
    "sources": "https://github.com/yourusername/redscope"
  },
  "license": "MIT",
  "icon": "assets/redscope/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.redscope.RedScopeMod"
    ],
    "client": [
      "com.redscope.RedScopeClientMod"
    ],
    "gametest": [
      "com.redscope.gametest.RedScopeGameTests",
      "com.redscope.gametest.ComplexCircuitTests"
    ]
  },
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": ">=26.1.2",
    "java": ">=25",
    "fabric-api": ">=0.151.0+26.1.2"
  },
  "suggests": {
    "modmenu": "*",
    "cloth-config": ">=17.0.143"
  },
  "mixins": [
    "redscope.mixins.json"
  ]
